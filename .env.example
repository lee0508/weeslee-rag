# PromptoRAG Environment Configuration
# Copy this file to .env and update values

# Application
APP_NAME=PromptoRAG
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=promptorag
DB_USER=root
DB_PASSWORD=

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Knowledge Sources (Network Drive)
# Windows 개발 환경: 매핑 드라이브(W:) 또는 UNC 경로 사용
# KNOWLEDGE_SOURCE_ROOT=W:\\
# KNOWLEDGE_SOURCE_UNC=\\\\diskstation\\W2_프로젝트폴더
# Linux 서버: NAS 마운트 경로 사용
KNOWLEDGE_SOURCE_ROOT=/mnt/w2_project

# Server (Production)
SERVER_HOST=192.168.0.207
SERVER_USER=weeslee
PROJECT_PATH=/data/weeslee/weeslee-rag
