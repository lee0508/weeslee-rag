# PromptoRAG Environment Configuration
# Copy this file to .env and update values

# Application
APP_NAME=PromptoRAG
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=promptorag
DB_USER=root
DB_PASSWORD=

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Server (Production)
SERVER_HOST=192.168.0.207
SERVER_USER=weeslee
PROJECT_PATH=/data/weeslee/weeslee-rag
